<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>QUOTATION</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: #e5e5e5;
      font-family: Arial, sans-serif;
      color: #000;
      overflow-x: auto;
      padding: 10px;
    }

    #customer_name,
    #customer_address,
    #kec_name {
      text-transform: uppercase;
    }

    /* PAGE */
    .page {
      width: 297mm;
      height: 200mm;
      margin: auto;
      background: #fff;
      border: 1px solid #000;
      overflow: hidden;
    }

    /* HEADER */
    .main-header {
      background: #1a3a6b;
      color: #fff;
      text-align: center;
      padding: 6px 0;
      font-size: 20px;
      font-weight: bold;
      letter-spacing: 1px;
      border-bottom: 1px solid #000;
    }

    /* TOP BAR */
    .top-bar {
      display: flex;
      align-items: stretch;
      border-bottom: 1px solid #000;
    }

    .top-bar .ser,
    .top-bar .date-sec {
      width: 220px;
      padding: 6px 10px;
      font-weight: bold;
      font-size: 12px;
      display: flex;
      align-items: center;
    }

    .top-bar .ser {
      border-right: 1px solid #000;
    }

    .top-bar .date-sec {
      justify-content: space-between;
      border-left: 1px solid #000;
    }

    .top-bar .quotation-title {
      flex: 1;
      background: yellow;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
      padding: 6px 0;
    }

    /* CUSTOMER TABLE */
    .customer-table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      border-bottom: 1px solid #000;
    }

    .customer-table td {
      border: 1px solid #000;
      padding: 4px 8px;
      font-size: 11px;
      height: 24px;
    }

    .customer-table .lbl {
      width: 220px;
      font-weight: bold;
    }

    .customer-table .val {
      text-align: center;
      font-weight: bold;
    }

    /* MAIN TABLE */
    .main-table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    .main-table td {
      border: 1px solid #000;
      padding: 4px 6px;
      font-size: 11px;
      height: 26px;
      vertical-align: middle;
    }

    .dark-header {
      background: #dfe7f5;
      font-weight: bold;
      text-align: center;
      font-size: 11px;
    }

    .row-label {
      font-weight: bold;
    }

    .row-value {
      text-align: center;
      font-weight: bold;
    }

    .main-model {
      text-align: center;
      font-weight: bold;
      font-size: 14px;
      line-height: 20px;
    }

    /* NOTE SECTION */
    .note-section {
      display: flex;
      border-top: 1px solid #000;
    }

    .note-left {
      flex: 2;
      padding: 5px 10px;
    }

    .note-right {
      flex: 1;
      padding: 6px;
      text-align: center;
      font-size: 11px;
      line-height: 1.5;
    }

    .note-highlight {
      background: yellow;
      font-weight: bold;
      font-size: 11px;
      padding: 2px 4px;
      margin-bottom: 4px;
      display: inline-block;
    }

    .note-item {
      font-size: 10px;
      line-height: 1.3;
      margin-bottom: 2px;
    }

    .rtgs-title {
      font-weight: bold;
      font-size: 11px;
      margin-bottom: 4px;
    }

    /* FOOTER */
    .footer-section {
      display: flex;
      height: 95px;
      border-top: 1px solid #000;
    }

    .footer-left {
      flex: 1.7;
      padding: 6px 8px;
      /* border-right: 1px solid #000; */
      font-size: 10px;
      line-height: 1.5;
    }

    .footer-right {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .kec-header {
      background: #1a3a6b;
      color: #fff;
      text-align: center;
      font-size: 11px;
      font-weight: bold;
      padding: 4px 0;
      border-bottom: 1px solid #000;
    }

    .footer-right-inner {
      flex: 1;
      border: 1px solid black;
      padding: 6px 10px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* SIGNATURE */
    .sig-area {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .sig-label-block {
      font-size: 11px;
      font-weight: bold;
    }

    .sig-space {
      width: 140px;
      height: 40px;
      border-bottom: 1px solid #000;
    }

    /* NAME */
    .name-block {
      margin-top: 4px;
    }

    .name-row {
      display: flex;
      align-items: center;
      margin-bottom: 3px;
      font-size: 11px;
    }

    .name-row .nl {
      min-width: 65px;
      font-weight: bold;
      background: yellow;
      padding-top: 4px;
      padding-bottom: 4px;
      padding-left: 4px;
    }

    .name-row .nv {
      flex: 1;
      font-weight: bold;
      padding: 2px 5px;
    }

    a {
      color: #1a3a6b;
      text-decoration: none;
    }

    /* BUTTON */
    .print-btn-wrap {
      width: 297mm;
      margin: 15px auto 10px;
      display: flex;
      justify-content: flex-end;
    }

    .print-btn {
      background: #1a3a6b;
      color: #fff;
      border: none;
      padding: 10px 20px;
      font-size: 13px;
      font-weight: bold;
      cursor: pointer;
      border-radius: 4px;
    }

    /* PRINT SETTINGS */
    @page {
      size: A4 landscape;
      margin: 0;
    }

    @media print {

      html,
      body {
        width: 100%;
        height: 100%;

        margin: 0 !important;
        padding: 0 !important;

        overflow: hidden !important;
        background: #fff;

        display: flex;

        /* PERFECT CENTER */
        justify-content: center;
        align-items: center;

        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      .print-btn-wrap {
        display: none !important;
      }

      .page {
        width: 297mm;
        height: 200mm;

        border: 1px solid #000;
        box-shadow: none;

        overflow: hidden !important;

        /* SINGLE PAGE */
        transform: scale(0.94);

        /* CENTER SCALE */
        transform-origin: center center;

        margin: 0 auto !important;

        position: relative;

        left: 0 !important;
        right: 0 !important;
      }

      * {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
      }
    }
  </style>
</head>

<body>

  <div class="print-btn-wrap">
    <button onclick="printQuotation()" class="print-btn">
