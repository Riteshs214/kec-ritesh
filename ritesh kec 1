      </tr>

      <tr>
        <td class="lbl">EMAIL :-</td>
        <td class="val" id="customer_email"></td>
      </tr>

    </table>

    <table class="main-table">

      <colgroup>
        <col style="width:22%">
        <col style="width:12%">
        <col style="width:12%">
        <col style="width:12%">
        <col style="width:12%">
        <col style="width:12%">
        <col style="width:8%">
        <col style="width:10%">
      </colgroup>

      <tr>
        <td class="dark-header">MODEL :-</td>
        <td class="dark-header" id="model"></td>

        <td class="dark-header">VARIANT</td>
        <td class="dark-header" id="variant"></td>

        <td class="dark-header">COLOUR</td>
        <td class="dark-header" id="color"></td>

        <td class="dark-header">FUEL</td>
        <td class="dark-header" id="fuel"></td>
      </tr>

      <tr>
        <td class="row-label">MODEL :-</td>
        <td colspan="7" class="main-model" id="description"></td>
      </tr>

<tr>
    <td class="row-label">EXSHOWROOM</td>
    <td class="row-value" id="ex_showroom"></td>
    <td class="row-value single-variant-extension" id="ex_showroom2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">COMP / ZERO DEP INS</td>
    <td class="row-value" id="insurance"></td>
    <td class="row-value single-variant-extension" id="insurance2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">REGISTRATION</td>
    <td class="row-value" id="registration"></td>
    <td class="row-value single-variant-extension" id="registration2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">ACCESSORIES / ESSENTIALS</td>
    <td class="row-value" id="accessories"></td>
    <td class="row-value single-variant-extension" id="accessories2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">EXTENDED WARRANTY</td>
    <td class="row-value" id="extended_warranty"></td>
    <td class="row-value single-variant-extension" id="extended_warranty2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">TCS</td>
    <td class="row-value" id="tcs"></td>
    <td class="row-value single-variant-extension" id="tcs2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">FASTAG</td>
    <td class="row-value" id="fastag"></td>
    <td class="row-value single-variant-extension" id="fastag2" colspan="6"></td>
</tr>

<tr>
    <td class="row-label">ON ROAD</td>
    <td class="row-value" id="on_road"></td>
    <td class="row-value single-variant-extension" id="on_road2" colspan="6"></td>
</tr>

    </table>

    <div class="note-section">

      <div class="note-left">

        <div class="note-highlight">
          NOTE - SELTOS WAITING PERIOD IS 4 TO 8 WEEKS OFFICIAL
        </div>

        <div class="note-item">
          1 - Price prevailing at the time of invoicing will be applicable.
        </div>

        <div class="note-item">
          2 - Registration price includes registration fee, HPA charges and taxes.
        </div>

        <div class="note-item">
          3 - Vehicle home delivery charges extra.
        </div>

        <div class="note-item">
          4 - Cheque payment considered only after clearance from bank.
        </div>

        <div class="note-item">
          5 - All disputes are subject to Jabalpur jurisdiction.
        </div>

        <div class="note-item">
          6 - Vehicle delivery will be done after full payment confirmation.
        </div>

        <div class="note-item">
          7 - Vehicle delivery subject to manufacturer availability.
        </div>

        <div class="note-item">
          8 - Required documents: Address Proof & PAN Card.
        </div>

      </div>

      <div class="note-right">

        <div class="rtgs-title">DETAILS FOR RTGS</div>

        <div>KHATWANI SALES AND SERVICES LLP</div>
        <div>HDFC BANK</div>
        <div>GOLBAZAR JABALPUR</div>
        <div>A/C NO - 50200038843736</div>
        <div>IFSC - HDFC0000224</div>

      </div>

    </div>

    <div class="footer-section">

      <div class="footer-left">

        <div><strong>KHATWANI SALES AND SERVICES LLP</strong></div>

        <div>KIA INDIA</div>

        <div>Sales & Service</div>

        <div>
          509/4D Near Tripuri Chowk, Madan Mahal Road,
          Garha Jabalpur (MP) - 482003
        </div>

        <div>
          16-17 Tilwara Nagpur Road Near Radha Swami Satsang,
          Jabalpur (MP) - 480003
        </div>

        <div>
          <a href="mailto:khatwanikia.edp@gmail.com">
            khatwanikia.edp@gmail.com
          </a>
        </div>

      </div>

      <div class="footer-right">

        <div class="kec-header">
          KEC
        </div>

        <div class="footer-right-inner">

          <div class="sig-area">

            <div class="sig-label-block">
              SIGNATURE
            </div>

            <div class="sig-space">
              <img
                src="https://blogger.googleusercontent.com/img/a/AVvXsEgfHbMFEhbHnxTcp8QcCniHA9TY_rZSJy7ifzK7MI8kmnErH0TuOtuywG8eJV0MFTRUVfuhx-jJbZtSB8jXTT06yY5ZY7lEDntBCFi9CRbFI5DwzGyd_bhZ1D3DkMRpHW_lotJ430r7dd2mjWf-OE2VUu9M9XqKzJ7C23xX80s-MsTtoljp0PKAHFLo0W8"
                alt="" style="width: 147px;">
            </div>

          </div>

          <div class="name-block">

            <div class="name-row">
              <span class="nl">NAME :-</span>
              <span class="nv" id="kec_name"></span>
            </div>

            <div class="name-row">
              <span class="nl">MO.NO :-</span>
              <span class="nv" id="kec_mobile"></span>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

  <script>

    function printQuotation() {
      window.print();
    }

    // GET URL DATA
    const params =
      new URLSearchParams(
        window.location.search
      );

    // FORMAT PRICE
    function formatPrice(value) {

      if (value == null || value == "")
        return "0";

      return Number(value)
        .toLocaleString("en-IN");

    }

    // FORMAT DATE
    let formattedDate = "";

    const rawDate =
      params.get("quotation_date");

    if (rawDate) {

      const parts =
        rawDate.split("-");

      formattedDate =
        `${parts[2]}-${parts[1]}-${parts[0]}`;

    }

    // CUSTOMER
    document.getElementById("customer_name").innerText =
      params.get("customer_name") || "";

    document.getElementById("customer_address").innerText =
      params.get("customer_address") || "";

    document.getElementById("customer_phone").innerText =
      params.get("customer_phone") || "";

    document.getElementById("customer_email").innerText =
      params.get("customer_email") || "";

    document.getElementById("quotation_date").innerText =
      formattedDate;

    document.getElementById("kec_name").innerText =
      params.get("kec_name") || "";

    document.getElementById("kec_mobile").innerText =
      params.get("kec_mobile") || "";

    // CAR
    document.getElementById("model").innerText =
      params.get("model") || "";

    const variant =
      params.get("variant") || "";

    const variant2 =
      params.get("variant2") || "";

    document.getElementById("variant").innerText =
      variant2 ? "" : variant;

    document.getElementById("fuel").innerText =
      params.get("fuel") || "";

    document.getElementById("color").innerText =
      params.get("color") || "";

    document.getElementById("description").innerText =
      params.get("description") || "";

    // PRICES
    document.getElementById("ex_showroom").innerText =
      formatPrice(params.get("ex_showroom"));

    document.getElementById("insurance").innerText =
      formatPrice(params.get("insurance"));

    document.getElementById("registration").innerText =
      formatPrice(params.get("registration"));

    document.getElementById("accessories").innerText =
      formatPrice(params.get("accessories"));

    document.getElementById("extended_warranty").innerText =
      formatPrice(params.get("extended_warranty"));

    document.getElementById("tcs").innerText =
      formatPrice(params.get("tcs"));

    document.getElementById("fastag").innerText =
      formatPrice(params.get("fastag"));

    //document.getElementById("on_road").innerText = formatPrice(params.get("on_road"));
    const total =
      Number(params.get("ex_showroom") || 0) +
      Number(params.get("insurance") || 0) +
      Number(params.get("registration") || 0) +
      Number(params.get("accessories") || 0) +
      Number(params.get("extended_warranty") || 0) +
      Number(params.get("tcs") || 0) +
      Number(params.get("fastag") || 0);

    document.getElementById("on_road").innerText = formatPrice(total);
if (variant2) {

  document
    .querySelectorAll(".single-variant-extension")
    .forEach(cell => {
      cell.colSpan = 1;
    });

  [
    "ex_showroom2",
    "insurance2",
    "registration2",
    "accessories2",
    "extended_warranty2",
    "tcs2",
    "fastag2",
    "on_road2"
  ].forEach(id => {
    document.getElementById(id).style.display = "";
  });

  document.getElementById("ex_showroom2").innerText =
    formatPrice(params.get("ex_showroom2"));

  document.getElementById("insurance2").innerText =
    formatPrice(params.get("insurance2"));

  document.getElementById("registration2").innerText =
    formatPrice(params.get("registration2"));

  document.getElementById("accessories2").innerText =
    formatPrice(params.get("accessories2"));

  document.getElementById("extended_warranty2").innerText =
    formatPrice(params.get("extended_warranty2"));

  document.getElementById("tcs2").innerText =
    formatPrice(params.get("tcs2"));

  document.getElementById("fastag2").innerText =
    formatPrice(params.get("fastag2"));

  const total2 =
    Number(params.get("ex_showroom2") || 0) +
    Number(params.get("insurance2") || 0) +
    Number(params.get("registration2") || 0) +
    Number(params.get("accessories2") || 0) +
    Number(params.get("extended_warranty2") || 0) +
    Number(params.get("tcs2") || 0) +
    Number(params.get("fastag2") || 0);

  document.getElementById("on_road2").innerText =
    formatPrice(total2);
}
  </script>
</body>

</html>
